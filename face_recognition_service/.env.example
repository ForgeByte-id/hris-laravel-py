# WITHOUT DOCKER (local): use 127.0.0.1 and your local MySQL port
# WITH DOCKER:            values are injected via docker-compose env_file
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hris_db
DB_USERNAME=root
DB_PASSWORD=

FACE_THRESHOLD=0.6

# Temp directory where this service reads face images written by Laravel.
#
# WITHOUT DOCKER (local dev):
#   Set this to the absolute path of the Laravel project storage/app/temp directory.
#   It must exactly match what FACE_TEMP_DIR resolves to on the PHP side
#   (which defaults to {project_root}/storage/app/temp when FACE_TEMP_DIR is blank).
#
#   Example (adjust to your machine):
#     ALLOWED_IMAGE_TMP_DIR=/Users/yourname/Projects/hris/storage/app/temp
#
# WITH DOCKER:
#   Already set to /var/www/html/storage/app/temp via docker-compose.yml.
#   Do not override here for Docker deployments.
ALLOWED_IMAGE_TMP_DIR=

