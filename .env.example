APP_NAME=HRIS-WEB
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

AUTH_GUARD=user

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ======================
# DATABASE (FIXED)
# ======================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# ======================
# SESSION
# ======================
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=localhost

# ======================
# CACHE / QUEUE
# ======================
CACHE_STORE=file
QUEUE_CONNECTION=database

# ======================
# REDIS (optional)
# ======================
REDIS_HOST=redis

# ======================
# FACE RECOGNITION SERVICE
# ======================

# URL of the Python face recognition service
#
# WITHOUT DOCKER (local): FACE_SERVICE_URL=http://localhost:5000
# WITH DOCKER:            FACE_SERVICE_URL=http://face-service:5000
#   "face-service" is the container_name in docker-compose.yml.
#   docker-compose.yml already overrides this via the environment section;
#   keep http://localhost:5000 here so local dev works without any changes.
FACE_SERVICE_URL=http://localhost:5000

# Temp directory where Laravel writes face images for the Python service to read.
#
# WITHOUT DOCKER (local dev):
#   Leave this blank — Laravel defaults to storage/app/temp inside the project.
#   You MUST set ALLOWED_IMAGE_TMP_DIR in face_recognition_service/.env to the
#   same absolute path. Example:
#     FACE_TEMP_DIR=                                   (blank = auto)
#     ALLOWED_IMAGE_TMP_DIR=/absolute/path/to/hris/storage/app/temp
#
#   Windows example:
#     FACE_TEMP_DIR=C:/xampp/htdocs/hris/storage/app/temp
#     ALLOWED_IMAGE_TMP_DIR=C:/xampp/htdocs/hris/storage/app/temp
#
# WITH DOCKER:
#   Already set to /var/www/html/storage/app/temp via docker-compose.yml.
#   Do not override here for Docker deployments.
FACE_TEMP_DIR=

# ======================
# MAIL
# ======================
MAIL_MAILER=log
MAIL_HOST=mailhog
MAIL_PORT=1025

VITE_APP_NAME="${APP_NAME}"
