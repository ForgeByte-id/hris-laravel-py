APP_NAME=HRIS-WEB
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

AUTH_GUARD=user

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ======================
# DATABASE (FIXED)
# ======================
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# ======================
# SESSION
# ======================
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=localhost

# ======================
# CACHE / QUEUE
# ======================
CACHE_STORE=file
QUEUE_CONNECTION=database

# ======================
# REDIS (optional)
# ======================
REDIS_HOST=redis

# ======================
# FACE SERVICE (NEW)
# ======================
FACE_SERVICE_URL=http://localhost:5000

# ======================
# MAIL
# ======================
MAIL_MAILER=log
MAIL_HOST=mailhog
MAIL_PORT=1025

VITE_APP_NAME="${APP_NAME}"
