  box-shadow: var(--#{$prefix}avatar-box-shadow);
  transition: color $transition-time, background-color $transition-time, box-shadow $transition-time;

  .icon {
    width: var(--#{$prefix}avatar-icon-size);
    height: var(--#{$prefix}avatar-icon-size);
  }

  .badge {
    position: absolute;
